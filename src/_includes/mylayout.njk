---
title: My dope Blog
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- All SEO meta tags generated automatically -->
   {% seoMetaTags page.url, title, description, author, date %}
    
    <title>{{ title }} | Phil's Blog</title>
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/_includes/assets/apple-touch-icon.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/_includes/assets/favicon-32x32.png' | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/_includes/assets/favicon-16x16.png' | url }}">
    <link rel="manifest" href="{{ '/_includes/assets/site.webmanifest' | url }}">

    <link rel="preload" href="{{ '/_includes/assets/main.css' | url }}" as="style">
    <link rel="stylesheet" href="{{ '/_includes/assets/main.css' | url }}">
    <link rel="stylesheet" href="{{ '/_includes/assets/prism-one-light.css' | url}}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ '/_includes/assets/prism-one-light.css' | url}}"></noscript>

</head>
<body>
    <a href="#main-content" class="skip-link" style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;">Skip to main content</a>
    <nav aria-label="Breadcrumb"><div style="position: fixed"><a href="{{ '/' | url }}">Back</a></div></nav>

    <main id="main-content">
        <article itemscope itemtype="http://schema.org/BlogPosting">
            <header>
                <h1 itemprop="headline">{{ title }}</h1>
                {% if author and date %}
                <div class="post-meta">
                    <span itemprop="author" itemscope itemtype="http://schema.org/Person">
                        By <span itemprop="name">{{ author }}</span>
                    </span>
                    <time itemprop="datePublished" datetime="{{ date | schemaDate }}">{{ date | formatDate }}</time>
                </div>
                {% endif %}
            </header>
            <div itemprop="articleBody">
                {{ content | safe }}
            </div>

        {% set relatedPosts = collections.all | getRelatedPosts(page.url, tags) %}

        {% if relatedPosts.length > 0 %}
        <div style="margin-top: 4rem; padding-top: 1rem; border-top: 2px dashed #eee; font-family: monospace;">
            <strong>>> SEE_ALSO:</strong>
            
            <div style="margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.5rem;">
                {% for post in relatedPosts %}
                <div>
                    <!-- Assuming formatDate is an existing 11ty filter you have -->
                    <span style="color: #666;">{{ post.date | formatDate }}</span> | 
                    <a href="{{ post.url | url }}">{{ post.data.title }}</a>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
        </article>
    </main>
</body>
</html>
